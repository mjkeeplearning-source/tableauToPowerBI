            "type": "string"
          },
          "title": "Source Fields",
          "type": "array"
        },
        "source_sheet_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Sheet Ids",
          "type": "array"
        },
        "target_fields": {
