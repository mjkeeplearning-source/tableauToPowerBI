    "Datasource": {
      "additionalProperties": false,
      "description": "One `<datasource>` from the Tableau workbook, canonicalized.\n\n`pbi_m_connector` is None iff `connector_tier == TIER_4`. Credentials\nare never persisted here (\u00a75.8 credentials policy).",
