    "ConnectorTier": {
      "description": "Connector classification per \u00a75.8.\n\nTier 1: full fidelity (file/DB connectors emitting real M).\nTier 2: credential placeholders (user enters creds on first Desktop open).\nTier 3: degraded fidelity (cross-DB joins, blends, custom SQL).\nTier 4: unsupported (forces workbook status \u2192 failed).",
      "enum": [
        1,
        2,
        3,
        4
      ],
      "title": "ConnectorTier",
      "type": "integer"
    },
    "Container": {
      "additionalProperties": false,
      "properties": {
        "background": {
          "anyOf": [
